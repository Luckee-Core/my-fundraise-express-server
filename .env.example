# Supabase (required for /api/data)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic (required for investor-extract and pitch-deck-slide-studio)
ANTHROPIC_API_KEY=

# Server
PORT=3009
NODE_ENV=development

# Production CORS — comma-separated browser origins (when web calls Express directly)
# CORS_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# Optional: Cursor agent TSX generation for graphics
CURSOR_API_KEY=
CURSOR_TARGET_REPO=
