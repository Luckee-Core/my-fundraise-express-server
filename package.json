{
  "name": "express-server-template",
  "version": "1.0.0",
  "description": "Express API Server Template - Ready-to-use Express server with TypeScript",
  "main": "index.ts",
  "scripts": {
    "start": "ts-node index.ts",
    "dev": "nodemon --exec ts-node index.ts",
    "build": "tsc",
    "build:watch": "tsc --watch",
    "generate:deck-e-seed": "npm run build && node scripts/generate-deck-e-seed-sql.mjs",
    "generate:deck-e-graphics-seed": "npm run build && node scripts/generate-deck-e-graphics-seed-sql.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.106.0",
    "@supabase/supabase-js": "^2.108.2",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "uuid": "^14.0.1",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "^25.9.1",
    "@types/ws": "^8.18.1",
    "nodemon": "^3.1.11",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
